# ─────────────────────────────────────────────────────────────────────────────
# .env.local — Local development secrets (git-ignored)
# ─────────────────────────────────────────────────────────────────────────────
# This file is loaded by BOTH the Node.js portal (via dotenv) and Python
# scripts (via scripts/config.py). It is git-ignored and never committed.
#
# SECURITY PRECEDENCE (most secure → least):
#   1. Azure Key Vault  — production, secrets loaded at runtime via Managed Identity
#   2. .env.local       — local dev, never committed, overrides portal/.env
#   3. portal/.env      — portal-specific config, git-ignored
#
# To set up:
#   1. Copy this file to .env.local (remove the .example suffix)
#   2. Fill in your values
#   3. Both Node.js and Python scripts will pick them up automatically
# ─────────────────────────────────────────────────────────────────────────────

# Azure / Entra ID
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# Key Vault (recommended for production — leave empty for local dev)
AZURE_KEYVAULT_URL=

# Census API
CENSUS_API_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Power Platform (uses delegated auth — no secrets needed here)
# Authentication happens via device code flow at runtime.

# MCP Server
MCP_SERVER_URL=
