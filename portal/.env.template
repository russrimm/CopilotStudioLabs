# ─────────────────────────────────────────────────────────────────────────────
# Copilot Studio Labs — Provisioning Portal Configuration
# Copy this file to .env and fill in the values for your deployment.
# ⚠️  NEVER commit the .env file — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Portal ───────────────────────────────────────────────────────────────────
PORT=3000

# ── Azure / Entra ID ─────────────────────────────────────────────────────────
# Required for Microsoft Graph email transport and Azure resource deployment.
AZURE_TENANT_ID=f33d7d7f-d7a8-49c9-9dfe-af8c9ca30123
AZURE_CLIENT_ID=32c72b33-a331-4545-ad5a-6d2fdf961c4c
AZURE_CLIENT_SECRET=Cni8Q~zilrZ3JJU5nte6d.JhpR6lzGCiYmiguaf~
AZURE_SUBSCRIPTION_ID=4b2df633-d9f8-4261-adf9-226dd6f19033

# ── Azure Key Vault (RECOMMENDED for production) ────────────────────────────
# When set, secrets are loaded from Key Vault at startup instead of .env.
# The portal uses Managed Identity (preferred) or az CLI credentials.
# Secrets stored: azure-client-secret, smtp-password, census-api-key
AZURE_KEYVAULT_URL=

# ── Email — Option 1: SMTP ──────────────────────────────────────────────────
# Use this for direct SMTP relay (Exchange Online, SendGrid, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ── Email — Option 2: Microsoft Graph ────────────────────────────────────────
# Uses the Azure credentials above. MAIL_FROM must be a licensed mailbox.
# If both SMTP and Graph are configured, SMTP takes priority.

# ── Deployment Targets ───────────────────────────────────────────────────────
AZURE_WEBAPP_NAME=
AZURE_RESOURCE_GROUP=

# ── Container Registry ──────────────────────────────────────────────────────
AZURE_ACR_NAME=
AZURE_ACR_IMAGE=copilot-labs-portal:latest

# ── MCP Server ──────────────────────────────────────────────────────────────
MCP_SERVER_URL=

# ── Power Platform ──────────────────────────────────────────────────────────
POWER_PLATFORM_ENV=
POWER_PLATFORM_TENANT_ID=

# Power Platform Admin — delegated (user) auth via device code flow.
# Uses AZURE_CLIENT_ID and AZURE_TENANT_ID by default.
# Set these overrides if you use a separate app registration for PP admin:
# PP_CLIENT_ID=
# PP_TENANT_ID=

# ── Feature Flags ────────────────────────────────────────────────────────────
# ENABLE_GRAPH_EMAIL=true
# ENABLE_AZURE_DEPLOY=true

# ── Lab-specific API Keys ────────────────────────────────────────────────────
# Lab 04: US Census Bureau API key (free — https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=
