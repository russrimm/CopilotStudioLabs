# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/*
!.squad/orchestration-log/.gitkeep
.squad/log/*
!.squad/log/.gitkeep
.squad/decisions/inbox/*
!.squad/decisions/inbox/.gitkeep
.squad/sessions/
.squad/.scratch/
.squad/.cache/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Node
node_modules/

# Template setup
*.config.local.json

# Secrets
portal/.env
.env
.env.local
.env.*.local
portal/.env.local
portal/.env.*.local
portal/data/
portal/public/uploads/
